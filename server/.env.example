PORT=3001
FAIRY_DB_PATH=./data/thefairies.sqlite
CORS_ORIGIN=http://localhost:8000
LIFX_TOKEN=your_lifx_token_here
HUBITAT_TOKEN=your_hubitat_maker_api_token
