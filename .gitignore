# =============================================================================
# The Fairies v3 — .gitignore
# Based on Coding Fairy standard template
# =============================================================================

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Node / TypeScript
# -----------------------------------------------------------------------------
node_modules/
dist/
.cache/
.turbo/
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
.vite/

# -----------------------------------------------------------------------------
# Testing output (Playwright, Jest, etc.)
# -----------------------------------------------------------------------------
.testing/results/
test-results/
playwright-report/
playwright/.cache/
.playwright/
blob-report/
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Generated content (agent output, screenshots, reports)
# -----------------------------------------------------------------------------
generated/
scratchpad/
screenshots/
videos/
recordings/
**/*.mp4
**/*.webm

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# LLM artefacts & traces
# -----------------------------------------------------------------------------
.cache/llm/
traces/
artifacts/generated/

# -----------------------------------------------------------------------------
# MCP / process files
# -----------------------------------------------------------------------------
*.pid
*.sock
.mcp-lock

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.vercel
.netlify
*.env.old
